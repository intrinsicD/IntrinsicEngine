#pragma once

#include <functional>
#include <type_traits>
#include <utility>
#include <variant>

namespace std
{
    template <typename E>
    class unexpected
    {
    public:
        using error_type = E;

        constexpr unexpected(const E& error) : m_Error(error) {}
        constexpr unexpected(E&& error) : m_Error(std::move(error)) {}

        [[nodiscard]] constexpr E& error() & noexcept { return m_Error; }
        [[nodiscard]] constexpr const E& error() const & noexcept { return m_Error; }
        [[nodiscard]] constexpr E&& error() && noexcept { return std::move(m_Error); }
        [[nodiscard]] constexpr const E&& error() const && noexcept { return std::move(m_Error); }

    private:
        E m_Error;
    };

    template <typename E>
    unexpected(E) -> unexpected<E>;

    template <typename T, typename E>
    class expected
    {
    public:
        using value_type = T;
        using error_type = E;

        constexpr expected() requires std::is_default_constructible_v<T>
            : m_Data(std::in_place_index<0>)
        {
        }

        constexpr expected(const T& value) : m_Data(value) {}
        constexpr expected(T&& value) : m_Data(std::move(value)) {}
        constexpr expected(const unexpected<E>& error) : m_Data(error.error()) {}
        constexpr expected(unexpected<E>&& error) : m_Data(std::move(error.error())) {}

        constexpr expected(const expected&) = default;
        constexpr expected(expected&&) noexcept = default;
        constexpr expected& operator=(const expected&) = default;
        constexpr expected& operator=(expected&&) noexcept = default;

        [[nodiscard]] constexpr bool has_value() const noexcept { return m_Data.index() == 0; }
        [[nodiscard]] constexpr explicit operator bool() const noexcept { return has_value(); }

        [[nodiscard]] constexpr T& value() & { return std::get<0>(m_Data); }
        [[nodiscard]] constexpr const T& value() const & { return std::get<0>(m_Data); }
        [[nodiscard]] constexpr T&& value() && { return std::move(std::get<0>(m_Data)); }
        [[nodiscard]] constexpr const T&& value() const && { return std::move(std::get<0>(m_Data)); }

        [[nodiscard]] constexpr T& operator*() & { return value(); }
        [[nodiscard]] constexpr const T& operator*() const & { return value(); }
        [[nodiscard]] constexpr T&& operator*() && { return std::move(value()); }
        [[nodiscard]] constexpr const T&& operator*() const && { return std::move(value()); }

        [[nodiscard]] constexpr T* operator->() { return std::addressof(value()); }
        [[nodiscard]] constexpr const T* operator->() const { return std::addressof(value()); }

        [[nodiscard]] constexpr E& error() & { return std::get<1>(m_Data); }
        [[nodiscard]] constexpr const E& error() const & { return std::get<1>(m_Data); }
        [[nodiscard]] constexpr E&& error() && { return std::move(std::get<1>(m_Data)); }
        [[nodiscard]] constexpr const E&& error() const && { return std::move(std::get<1>(m_Data)); }

        [[nodiscard]] constexpr T value_or(T fallback) const &
        {
            return has_value() ? value() : std::move(fallback);
        }

        [[nodiscard]] constexpr T value_or(T fallback) &&
        {
            return has_value() ? std::move(value()) : std::move(fallback);
        }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) &
        {
            using Result = std::invoke_result_t<F, T&>;
            if (has_value()) return std::invoke(std::forward<F>(f), value());
            return Result(unexpected<E>(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) const &
        {
            using Result = std::invoke_result_t<F, const T&>;
            if (has_value()) return std::invoke(std::forward<F>(f), value());
            return Result(unexpected<E>(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) &&
        {
            using Result = std::invoke_result_t<F, T&&>;
            if (has_value()) return std::invoke(std::forward<F>(f), std::move(value()));
            return Result(unexpected<E>(std::move(error())));
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) &
        {
            if (has_value()) return *this;
            return std::invoke(std::forward<F>(f), error());
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) const &
        {
            if (has_value()) return *this;
            return std::invoke(std::forward<F>(f), error());
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) &&
        {
            if (has_value()) return std::move(*this);
            return std::invoke(std::forward<F>(f), std::move(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) &
        {
            using Result = std::invoke_result_t<F, T&>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f), value());
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(error()));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f), value()));
                return expected<Result, E>(unexpected<E>(error()));
            }
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) const &
        {
            using Result = std::invoke_result_t<F, const T&>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f), value());
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(error()));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f), value()));
                return expected<Result, E>(unexpected<E>(error()));
            }
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) &&
        {
            using Result = std::invoke_result_t<F, T&&>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f), std::move(value()));
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(std::move(error())));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f), std::move(value())));
                return expected<Result, E>(unexpected<E>(std::move(error())));
            }
        }

    private:
        std::variant<T, E> m_Data;
    };

    template <typename E>
    class expected<void, E>
    {
    public:
        using value_type = void;
        using error_type = E;

        constexpr expected() noexcept = default;
        constexpr expected(const unexpected<E>& error) : m_HasValue(false), m_Error(error.error()) {}
        constexpr expected(unexpected<E>&& error) : m_HasValue(false), m_Error(std::move(error.error())) {}

        constexpr expected(const expected&) = default;
        constexpr expected(expected&&) noexcept = default;
        constexpr expected& operator=(const expected&) = default;
        constexpr expected& operator=(expected&&) noexcept = default;

        [[nodiscard]] constexpr bool has_value() const noexcept { return m_HasValue; }
        [[nodiscard]] constexpr explicit operator bool() const noexcept { return has_value(); }

        constexpr void value() const noexcept {}

        [[nodiscard]] constexpr E& error() & { return m_Error; }
        [[nodiscard]] constexpr const E& error() const & { return m_Error; }
        [[nodiscard]] constexpr E&& error() && { return std::move(m_Error); }
        [[nodiscard]] constexpr const E&& error() const && { return std::move(m_Error); }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) &
        {
            using Result = std::invoke_result_t<F>;
            if (has_value()) return std::invoke(std::forward<F>(f));
            return Result(unexpected<E>(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) const &
        {
            using Result = std::invoke_result_t<F>;
            if (has_value()) return std::invoke(std::forward<F>(f));
            return Result(unexpected<E>(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto and_then(F&& f) &&
        {
            using Result = std::invoke_result_t<F>;
            if (has_value()) return std::invoke(std::forward<F>(f));
            return Result(unexpected<E>(std::move(error())));
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) &
        {
            if (has_value()) return *this;
            return std::invoke(std::forward<F>(f), error());
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) const &
        {
            if (has_value()) return *this;
            return std::invoke(std::forward<F>(f), error());
        }

        template <typename F>
        [[nodiscard]] constexpr expected or_else(F&& f) &&
        {
            if (has_value()) return std::move(*this);
            return std::invoke(std::forward<F>(f), std::move(error()));
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) &
        {
            using Result = std::invoke_result_t<F>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f));
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(error()));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f)));
                return expected<Result, E>(unexpected<E>(error()));
            }
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) const &
        {
            using Result = std::invoke_result_t<F>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f));
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(error()));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f)));
                return expected<Result, E>(unexpected<E>(error()));
            }
        }

        template <typename F>
        [[nodiscard]] constexpr auto transform(F&& f) &&
        {
            using Result = std::invoke_result_t<F>;
            if constexpr (std::is_void_v<Result>)
            {
                if (has_value())
                {
                    std::invoke(std::forward<F>(f));
                    return expected<void, E>{};
                }
                return expected<void, E>(unexpected<E>(std::move(error())));
            }
            else
            {
                if (has_value()) return expected<Result, E>(std::invoke(std::forward<F>(f)));
                return expected<Result, E>(unexpected<E>(std::move(error())));
            }
        }

    private:
        bool m_HasValue = true;
        E m_Error{};
    };
}


