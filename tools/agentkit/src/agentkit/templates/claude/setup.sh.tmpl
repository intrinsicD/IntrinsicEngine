#!/usr/bin/env bash
# {{PROJECT_NAME}} session-start hook (generated by agentkit).
#
# Provision whatever a fresh session needs (toolchain, dependencies, a warm
# build cache) so the agent starts ready to build and test. Fill in the TODO
# blocks for your stack.
#
# The structure gives you:
#   * a fast path  — already provisioned, return immediately;
#   * a slow path  — announce async, detach, provision in the background while
#                    the agent works in parallel.
#
# Completion is signalled by marker files under /tmp:
#   $DONE_MARKER (success)   $FAIL_MARKER (failure)
# Agents that must wait can call .claude/wait-for-setup.sh.
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOG="/tmp/{{MARKER_PREFIX}}-session-setup.log"
DONE_MARKER="/tmp/{{MARKER_PREFIX}}-session-setup.done"
FAIL_MARKER="/tmp/{{MARKER_PREFIX}}-session-setup.failed"

if [ "$(id -u)" -eq 0 ]; then SUDO=""; else SUDO="sudo"; fi

# --------------------------------------------------------------------------
# Fast path: already provisioned? Return immediately, no async, no log churn.
# --------------------------------------------------------------------------
environment_ready() {
    # TODO: a cheap probe that returns 0 when the environment is already ready.
    #   e.g.  command -v your-compiler >/dev/null 2>&1 \
    #      && command -v your-test-runner >/dev/null 2>&1
    return 1
}

if environment_ready; then
    printf '{{PROJECT_NAME}}: environment already provisioned; skipping.\n' >"$LOG"
    : >"$DONE_MARKER"; rm -f "$FAIL_MARKER"
    exit 0
fi

# --------------------------------------------------------------------------
# Slow path: announce async, detach IO, then provision in the background.
# The JSON line must be the ONLY thing on stdout before we detach.
# --------------------------------------------------------------------------
printf '{"async": true, "asyncTimeout": 1800000}\n'
rm -f "$DONE_MARKER" "$FAIL_MARKER"; : >"$LOG"
exec </dev/null >>"$LOG" 2>&1
trap 'echo "==> Provisioning FAILED (line $LINENO, rc=$?)."; : >"$FAIL_MARKER"; exit 1' ERR

echo "==> {{PROJECT_NAME}} session setup $(date -u +%Y-%m-%dT%H:%M:%SZ)"

# TODO: install system dependencies (keep idempotent — skip what is present).
#   $SUDO apt-get update -qq
#   DEBIAN_FRONTEND=noninteractive $SUDO apt-get install -y -qq <packages>

# TODO: configure and warm the build so the first in-session build is incremental.
#   ( cd "$PROJECT_ROOT" && {{CONFIGURE_CMD}} )
#   ( cd "$PROJECT_ROOT" && {{BUILD_CMD}} ) || true

echo "==> Setup complete $(date -u +%Y-%m-%dT%H:%M:%SZ)"
: >"$DONE_MARKER"
exit 0
