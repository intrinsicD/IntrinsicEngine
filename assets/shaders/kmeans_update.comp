#version 460

// GEOM-056 Slice B — k-means centroid update.
//
// One invocation per cluster: scan the current labels, recompute the centroid as
// the mean of its assigned points, or, when the cluster is empty, reseed it to
// the farthest point recorded in the per-point squared-distance buffer. The scan
// is intentionally portable: it avoids optional float atomics and replaces the
// earlier global atomic-add reduction until the shared segmented-reduction
// primitive lands.
//
// Requires an execution/memory barrier after the assignment pass so Sums,
// Counts, and the packed argmax are visible here (the runtime recorder inserts
// ShaderWrite -> ShaderRead between passes).

#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_buffer_reference2 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(buffer_reference, scalar) readonly buffer FloatArrayRO { float Values[]; };
layout(buffer_reference, scalar) readonly buffer UIntArrayRO { uint Values[]; };
layout(buffer_reference, scalar) buffer FloatArray { float Values[]; };

layout(buffer_reference, scalar) buffer KMeansReductionRef
{
    uint64_t PackedMaxDistIndex;
    float InertiaSum;
    uint ChangedCount;
    uint MaxShiftBits;
    uint Converged;
};

layout(buffer_reference, scalar) readonly buffer KMeansStateRef
{
    uint64_t PositionXBDA;
    uint64_t PositionYBDA;
    uint64_t PositionZBDA;
    uint64_t CentroidsBDA;
    uint64_t NextCentroidsBDA;
    uint64_t SumXBDA;
    uint64_t SumYBDA;
    uint64_t SumZBDA;
    uint64_t CountsBDA;
    uint64_t LabelsBDA;
    uint64_t SquaredDistancesBDA;
    uint64_t ReductionBDA;
};

layout(push_constant, scalar) uniform KMeansPush
{
    uint64_t StateBDA;
    uint PointCount;
    uint ClusterCount;
    uint GroupSize;
    uint Iteration;
    float ConvergenceTolSquared;
    float Reserved0;
} pc;

void main()
{
    const uint cluster = gl_GlobalInvocationID.x;
    if (cluster >= pc.ClusterCount || pc.StateBDA == uint64_t(0))
    {
        return;
    }

    KMeansStateRef state = KMeansStateRef(pc.StateBDA);
    FloatArray centroids = FloatArray(state.CentroidsBDA);

    const float oldX = centroids.Values[cluster * 3u + 0u];
    const float oldY = centroids.Values[cluster * 3u + 1u];
    const float oldZ = centroids.Values[cluster * 3u + 2u];

    FloatArrayRO px = FloatArrayRO(state.PositionXBDA);
    FloatArrayRO py = FloatArrayRO(state.PositionYBDA);
    FloatArrayRO pz = FloatArrayRO(state.PositionZBDA);
    UIntArrayRO labels = UIntArrayRO(state.LabelsBDA);
    FloatArrayRO distances = FloatArrayRO(state.SquaredDistancesBDA);

    float sumX = 0.0;
    float sumY = 0.0;
    float sumZ = 0.0;
    uint count = 0u;
    uint farthest = 0u;
    float farthestDistance = -1.0;

    for (uint index = 0u; index < pc.PointCount; ++index)
    {
        if (labels.Values[index] == cluster)
        {
            sumX += px.Values[index];
            sumY += py.Values[index];
            sumZ += pz.Values[index];
            ++count;
        }

        const float distance = distances.Values[index];
        if (distance > farthestDistance)
        {
            farthestDistance = distance;
            farthest = index;
        }
    }

    float newX;
    float newY;
    float newZ;
    if (count > 0u)
    {
        const float inv = 1.0 / float(count);
        newX = sumX * inv;
        newY = sumY * inv;
        newZ = sumZ * inv;
    }
    else
    {
        if (farthest >= pc.PointCount)
        {
            farthest = 0u;
        }
        newX = px.Values[farthest];
        newY = py.Values[farthest];
        newZ = pz.Values[farthest];
    }

    centroids.Values[cluster * 3u + 0u] = newX;
    centroids.Values[cluster * 3u + 1u] = newY;
    centroids.Values[cluster * 3u + 2u] = newZ;

    const float sdx = newX - oldX;
    const float sdy = newY - oldY;
    const float sdz = newZ - oldZ;
    const float shiftSquared = sdx * sdx + sdy * sdy + sdz * sdz;

    if (state.ReductionBDA != uint64_t(0))
    {
        // shiftSquared >= 0, so its float bits are monotonic under atomicMax.
        atomicMax(KMeansReductionRef(state.ReductionBDA).MaxShiftBits,
                  floatBitsToUint(shiftSquared));
    }
}
